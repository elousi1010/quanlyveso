# Dependencies (reinstalled in container)
node_modules

# Build output (built in container)
dist

# Version control
.git
.gitignore

# IDE & editor
.cursor
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Env (avoid leaking secrets into image)
.env
.env.*
!.env.example

# Logs & temp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.tmp
.temp
tmp
temp

# Test & coverage
coverage
.nyc_output
*.test.*
*.spec.*

# Docker (keep nginx.conf - used in Dockerfile)
Dockerfile
.dockerignore

# Scripts (dev/tooling, not needed for build)
*.sh

# Misc
*.md
.editorconfig
.prettierignore
.eslintcache
